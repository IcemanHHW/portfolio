<script>

// Calculate age based on birth date
const calculateAge = (birthDate: string): number => {
    const today = new Date();
    const birth = new Date(birthDate);
    
    let age = today.getFullYear() - birth.getFullYear();
    const monthDiff = today.getMonth() - birth.getMonth();
    
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {
        age--;
    }
    
    return age;
};

const birthDate: string = "1998-06-27";

// Update the element with the calculated age
const updateAgeText = (): void => {
    const ageElement = document.getElementById("age");
    if (ageElement) {
        ageElement.textContent = calculateAge(birthDate).toString();
    }
};

// Update immediately and then once per day
updateAgeText();
setInterval(updateAgeText, 24 * 60 * 60 * 1000);

</script>